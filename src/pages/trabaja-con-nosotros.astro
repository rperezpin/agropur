---
export const prerender = true

import PublicLayout from '../layouts/PublicLayout.astro'
import JobApplicationForm from '../components/shared/JobApplicationForm.tsx'

const title = 'Trabaja con Nosotros | Empleo en Gestión Agrícola | Agropur'
const description = 'Agropur busca tractoristas en Villafranca, Ejea y Huesca, administrativo/a en Ejea, y técnico agronómico/ambiental en prácticas. Empresa estable en gestión agrícola.'
const recaptchaSiteKey = import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY

const reasons = [
  { title: 'Trabajo real y estable', description: 'No buscamos candidatos para una lista de espera. Tenemos carga de trabajo ahora.', highlight: true },
  { title: 'Sector con futuro', description: 'La gestión medioambiental agrícola crece continuamente, impulsada por normativas cada vez más exigentes.' },
  { title: 'Aprendizaje continuo', description: 'Trabajarás con tecnología avanzada. El digestato de purín es solo el principio.' },
  { title: 'Impacto real', description: 'Tu trabajo contribuye directamente a la sostenibilidad del sector ganadero.' },
  { title: 'Empresa cercana', description: 'Somos un equipo pequeño. Aquí cada persona importa y sus ideas se escuchan.' },
]

const profiles = [
  {
    title: 'Tractorista',
    icon: '🚜',
    locations: ['Villafranca (Navarra)', 'Ejea de los Caballeros (Zaragoza)', 'Huesca (Huesca)'],
    locationsLabel: 'Tres ofertas independientes',
    requirements: [
      'Experiencia demostrable como tractorista',
      'Manejo de GPS agrícola',
      'Uso de PDA o dispositivos digitales',
      'Carnet de conducir (imprescindible)',
      'Se valorará formación agraria',
    ],
    offers: [
      'Trabajo estable',
      'Buenas condiciones salariales según experiencia',
      'Incorporación inmediata',
      'Trabajo con maquinaria moderna y tecnología avanzada',
    ],
  },
  {
    title: 'Administrativo/a',
    icon: '📋',
    locations: ['Ejea de los Caballeros (Zaragoza)'],
    requirements: [
      'Experiencia en gestión administrativa y contable',
      'Control de facturación y proveedores',
      'Manejo de herramientas ofimáticas (Excel, ERP, etc.)',
      'Se valorará experiencia en el sector agrícola',
    ],
    offers: [
      'Incorporación a empresa consolidada y en crecimiento',
      'Estabilidad laboral',
      'Buen ambiente de trabajo',
      'Posibilidades de desarrollo profesional',
    ],
  },
  {
    title: 'Técnico/a Agronómico o Ambiental',
    icon: '🔬',
    badge: 'Contrato de prácticas',
    locations: ['Ejea de los Caballeros (Zaragoza)'],
    requirements: [
      'Titulación en Ingeniería Agronómica, Ciencias Ambientales o similar',
      'Capacidad para elaborar planes de fertilización',
      'Interpretación de análisis de laboratorio',
      'Ganas de aprender en un entorno real',
    ],
    offers: [
      'Contrato de prácticas remunerado',
      'Mentoring directo con equipo técnico',
      'Incorporación a proyecto en crecimiento',
      'Posibilidad de continuidad',
    ],
  },
]

const steps = [
  { number: '1', title: 'Envía tu CV', description: 'Rellena el formulario y adjunta tu CV' },
  { number: '2', title: 'Te contactamos', description: 'Nos ponemos en contacto (normalmente en menos de 72h)' },
  { number: '3', title: 'Incorporación', description: 'Entrevista y, si hay encaje, incorporación' },
]
---

<PublicLayout title={title} description={description}>
  <Fragment slot="head">
    {recaptchaSiteKey && (
      <script is:inline src={`https://www.google.com/recaptcha/api.js?render=${recaptchaSiteKey}`}></script>
    )}
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "JobPosting",
      "title": "Operario/a de Maquinaria Agrícola",
      "hiringOrganization": {
        "@type": "Organization",
        "name": "Agropur Centro Gestor S.L.",
        "sameAs": "https://www.agropur.es"
      },
      "jobLocation": {
        "@type": "Place",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Ejea de los Caballeros",
          "addressRegion": "Zaragoza",
          "addressCountry": "ES"
        }
      },
      "employmentType": "FULL_TIME",
      "description": "Búsqueda continua de operarios/as para gestión de maquinaria agrícola."
    })} />
  </Fragment>

  <!-- Hero -->
  <section class="relative min-h-[60vh] flex items-center bg-blue-dark overflow-hidden">
    <div class="absolute inset-0 bg-green-primary/10 pointer-events-none"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-heading font-bold text-white leading-tight mb-6" data-aos="fade-up">
        Tenemos trabajo.
        <span class="block text-green-mid">Necesitamos personas.</span>
      </h1>
      <p class="text-lg sm:text-xl text-white/85 max-w-2xl mb-8" data-aos="fade-up" data-aos-delay="100">
        Agropur está creciendo y buscamos personas comprometidas que quieran formar parte de un proyecto real, con trabajo estable y futuro en el sector.
      </p>
      <a href="#perfiles" class="inline-flex items-center px-8 py-4 bg-white text-blue-dark font-semibold rounded-lg hover:bg-gray-brand transition-all shadow-lg" data-aos="fade-up" data-aos-delay="200">
        Ver perfiles abiertos ↓
      </a>
    </div>
  </section>

  <!-- Why Join -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-heading font-semibold text-green-primary text-center mb-10" data-aos="fade-up">
        Por qué unirte a Agropur
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {reasons.map((reason, i) => (
          <div
            class={`rounded-xl p-6 ${reason.highlight ? 'bg-blue-accent/5 border-2 border-blue-accent' : 'bg-gray-brand border border-gray-200'}`}
            data-aos="fade-up"
            data-aos-delay={i * 100}
          >
            <h3 class={`text-lg font-heading font-semibold mb-2 ${reason.highlight ? 'text-blue-accent' : 'text-black-soft'}`}>
              {reason.title}
            </h3>
            <p class="text-sm text-gray-mid leading-relaxed">{reason.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Open Profiles -->
  <section id="perfiles" class="py-16 lg:py-20 bg-gray-brand">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-heading font-semibold text-green-primary text-center mb-10" data-aos="fade-up">
        Perfiles abiertos
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {profiles.map((profile, i) => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-200 relative flex flex-col" data-aos="fade-up" data-aos-delay={i * 100}>
            {profile.badge && (
              <span class="absolute top-4 right-4 px-3 py-1 rounded-full bg-green-primary/10 text-green-primary text-xs font-bold uppercase">
                {profile.badge}
              </span>
            )}
            <div class="text-4xl mb-3">{profile.icon}</div>
            <h3 class="text-xl font-heading font-bold text-black-soft mb-2">{profile.title}</h3>

            {/* Ubicaciones */}
            <div class="flex flex-wrap gap-2 mb-4">
              {profile.locationsLabel && (
                <span class="text-xs text-blue-accent font-semibold uppercase tracking-wide w-full">{profile.locationsLabel}</span>
              )}
              {profile.locations.map((loc) => (
                <span class="inline-flex items-center gap-1 px-2 py-1 bg-gray-brand rounded text-xs text-gray-dark">
                  <svg class="w-3 h-3 text-green-primary flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
                  </svg>
                  {loc}
                </span>
              ))}
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-5 flex-1">
              {/* Requisitos */}
              <div>
                <h4 class="text-xs font-bold uppercase tracking-wide text-gray-mid mb-2">Requisitos</h4>
                <ul class="space-y-1">
                  {profile.requirements.map((req) => (
                    <li class="flex items-start gap-1.5 text-xs text-gray-dark">
                      <svg class="w-3.5 h-3.5 text-green-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                      </svg>
                      {req}
                    </li>
                  ))}
                </ul>
              </div>
              {/* Ofrecemos */}
              <div>
                <h4 class="text-xs font-bold uppercase tracking-wide text-gray-mid mb-2">Ofrecemos</h4>
                <ul class="space-y-1">
                  {profile.offers.map((offer) => (
                    <li class="flex items-start gap-1.5 text-xs text-gray-dark">
                      <svg class="w-3.5 h-3.5 text-blue-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                      </svg>
                      {offer}
                    </li>
                  ))}
                </ul>
              </div>
            </div>

            <a href="#formulario" class="inline-flex items-center gap-1 text-sm font-semibold text-blue-accent hover:underline mt-auto">
              Me interesa →
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Selection Process -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-heading font-semibold text-green-primary text-center mb-10" data-aos="fade-up">
        Proceso de selección
      </h2>
      <div class="flex flex-col md:flex-row items-center justify-center gap-8 lg:gap-12">
        {steps.map((step, i) => (
          <div class="flex flex-col items-center text-center relative" data-aos="fade-up" data-aos-delay={i * 150}>
            <div class="w-16 h-16 rounded-full bg-green-primary text-white flex items-center justify-center text-2xl font-heading font-bold mb-4">
              {step.number}
            </div>
            <h3 class="font-heading font-semibold text-black-soft mb-1">{step.title}</h3>
            <p class="text-sm text-gray-mid max-w-xs">{step.description}</p>
            {i < steps.length - 1 && (
              <svg class="hidden md:block absolute -right-6 lg:-right-8 top-8 w-6 h-6 text-blue-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Application Form -->
  <section id="formulario" class="py-16 lg:py-20 bg-gray-brand">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-heading font-semibold text-green-primary text-center mb-4" data-aos="fade-up">
        Envía tu candidatura
      </h2>
      <p class="text-gray-mid text-center mb-8" data-aos="fade-up" data-aos-delay="100">
        Rellena el formulario y adjunta tu CV en PDF.
      </p>
      <div data-aos="fade-up" data-aos-delay="200">
        <JobApplicationForm client:visible />
      </div>
    </div>
  </section>

  <!-- Closing -->
  <section class="py-12 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-lg text-gray-dark italic" data-aos="fade-up">
        ¿No encajas en ninguno de los perfiles? Mándanos tu CV igualmente. Si tienes ganas de trabajar con nosotros, buscamos la manera.
      </p>
    </div>
  </section>
</PublicLayout>
