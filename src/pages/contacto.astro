---
export const prerender = true

import PublicLayout from '../layouts/PublicLayout.astro'
import PageHero from '../components/shared/PageHero.astro'
import ContactForm from '../components/shared/ContactForm.tsx'

const title = 'Contacto | Agropur Centro Gestor S.L. — Ejea de los Caballeros'
const description = 'Contacta con Agropur para gestión de purines, digestato y servicios agronómicos en Aragón y Navarra.'
const recaptchaSiteKey = import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY
---

<PublicLayout title={title} description={description}>
  <Fragment slot="head">
    {recaptchaSiteKey && (
      <script is:inline src={`https://www.google.com/recaptcha/api.js?render=${recaptchaSiteKey}`}></script>
    )}
  </Fragment>
  <PageHero
    title="Contacta con Nosotros"
    subtitle="Tanto si eres ganadero, agricultor, o simplemente quieres saber más sobre nuestros servicios, estamos aquí para ayudarte."
    breadcrumbs={[{ label: 'Inicio', href: '/' }, { label: 'Contacto' }]}
  />

  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Form -->
        <div data-aos="fade-right">
          <h2 class="text-2xl font-heading font-semibold text-green-primary mb-6">
            Envíanos un mensaje
          </h2>
          <ContactForm client:load />
        </div>

        <!-- Contact Info -->
        <div data-aos="fade-left">
          <h2 class="text-2xl font-heading font-semibold text-green-primary mb-6">
            Información de contacto
          </h2>

          <div class="space-y-6 mb-8">
            <!-- Address -->
            <div class="flex items-start gap-4">
              <svg class="w-6 h-6 text-blue-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
              <div>
                <p class="font-semibold text-black-soft">Dirección</p>
                <p class="text-gray-mid">Ejea de los Caballeros, Zaragoza</p>
              </div>
            </div>

            <!-- Email -->
            <div class="flex items-start gap-4">
              <svg class="w-6 h-6 text-blue-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
              <div>
                <p class="font-semibold text-black-soft">Email</p>
                <a href="mailto:info@agropur.es" class="text-green-primary hover:underline">info@agropur.es</a>
              </div>
            </div>

            <!-- Phone -->
            <div class="flex items-start gap-4">
              <svg class="w-6 h-6 text-blue-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              <div>
                <p class="font-semibold text-black-soft">Teléfono</p>
                <a href="tel:+34617906103" class="text-green-primary hover:underline">+34 617 906 103</a>
              </div>
            </div>

            <!-- WhatsApp -->
            <div class="flex items-start gap-4">
              <svg class="w-6 h-6 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              <div>
                <p class="font-semibold text-black-soft">WhatsApp</p>
                <a
                  href="https://wa.me/34617906103?text=Hola!%2C%20estar%C3%ADa%20interesado%20en%20m%C3%A1s%20informaci%C3%B3n%20sobre.."
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 mt-1 px-4 py-2 bg-green-500 hover:bg-green-600 text-white text-sm font-medium rounded-lg transition-colors duration-200"
                >
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                  Escríbenos por WhatsApp
                </a>
              </div>
            </div>

            <!-- Schedule -->
            <div class="flex items-start gap-4">
              <svg class="w-6 h-6 text-blue-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="font-semibold text-black-soft">Horario</p>
                <p class="text-gray-mid">Lunes a Viernes: 8:00–18:00</p>
                <p class="text-gray-mid">Sábados: 9:00–13:00 (campaña)</p>
              </div>
            </div>
          </div>

          <!-- Map -->
          <div class="rounded-xl overflow-hidden shadow-sm border border-gray-200">
            <iframe
              src="https://www.openstreetmap.org/export/embed.html?bbox=-1.1847%2C42.1114%2C-1.1147%2C42.1414&amp;layer=mapnik&amp;marker=42.1264%2C-1.1497"
              width="100%"
              height="300"
              style="border:0"
              loading="lazy"
              title="Ubicación de Agropur en Ejea de los Caballeros"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>
</PublicLayout>
