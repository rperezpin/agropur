---
export const prerender = true

import PublicLayout from '../layouts/PublicLayout.astro'
import PageHero from '../components/shared/PageHero.astro'
import ContactForm from '../components/shared/ContactForm.tsx'

const title = 'Contacto | Agropur Centro Gestor S.L. — Ejea de los Caballeros'
const description = 'Contacta con Agropur para gestión de purines, digestato y servicios agronómicos en Aragón y Navarra.'
const recaptchaSiteKey = import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY
---

<PublicLayout title={title} description={description}>
  <Fragment slot="head">
    {recaptchaSiteKey && (
      <script is:inline src={`https://www.google.com/recaptcha/api.js?render=${recaptchaSiteKey}`}></script>
    )}
  </Fragment>
  <PageHero
    title="Contacta con Nosotros"
    subtitle="Tanto si eres ganadero, agricultor, o simplemente quieres saber más sobre nuestros servicios, estamos aquí para ayudarte."
    breadcrumbs={[{ label: 'Inicio', href: '/' }, { label: 'Contacto' }]}
  />

  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Form -->
        <div data-aos="fade-right">
          <h2 class="text-2xl font-heading font-semibold text-green-primary mb-6">
            Envíanos un mensaje
          </h2>
          <ContactForm client:load />
        </div>

        <!-- Contact Info -->
        <div data-aos="fade-left">
          <h2 class="text-2xl font-heading font-semibold text-green-primary mb-6">
            Información de contacto
          </h2>

          <div class="space-y-6 mb-8">
            <!-- Address -->
            <div class="flex items-start gap-4">
              <svg class="w-6 h-6 text-blue-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
              <div>
                <p class="font-semibold text-black-soft">Dirección</p>
                <p class="text-gray-mid">Ejea de los Caballeros, Zaragoza</p>
              </div>
            </div>

            <!-- Email -->
            <div class="flex items-start gap-4">
              <svg class="w-6 h-6 text-blue-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
              <div>
                <p class="font-semibold text-black-soft">Email</p>
                <a href="mailto:info@agropur.es" class="text-green-primary hover:underline">info@agropur.es</a>
              </div>
            </div>

            <!-- Phone — TODO: actualizar con número real del cliente -->
            <div class="flex items-start gap-4">
              <svg class="w-6 h-6 text-blue-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              <div>
                <p class="font-semibold text-black-soft">Teléfono</p>
                <p class="text-gray-mid text-sm italic">Pendiente de publicar</p>
              </div>
            </div>

            <!-- Schedule -->
            <div class="flex items-start gap-4">
              <svg class="w-6 h-6 text-blue-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="font-semibold text-black-soft">Horario</p>
                <p class="text-gray-mid">Lunes a Viernes: 8:00–18:00</p>
                <p class="text-gray-mid">Sábados: 9:00–13:00 (campaña)</p>
              </div>
            </div>
          </div>

          <!-- Map -->
          <div class="rounded-xl overflow-hidden shadow-sm border border-gray-200">
            <iframe
              src="https://www.openstreetmap.org/export/embed.html?bbox=-1.1847%2C42.1114%2C-1.1147%2C42.1414&amp;layer=mapnik&amp;marker=42.1264%2C-1.1497"
              width="100%"
              height="300"
              style="border:0"
              loading="lazy"
              title="Ubicación de Agropur en Ejea de los Caballeros"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>
</PublicLayout>
