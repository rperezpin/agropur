---
export const prerender = true

import PublicLayout from '../layouts/PublicLayout.astro'
import PageHero from '../components/shared/PageHero.astro'

const title = 'Servicios de Gestión de Purines | Agropur Centro Gestor'
const description = 'Servicio para ganaderos y agricultores: análisis NPK, transporte granja-agricultor, tubos colgantes, gestión administrativa y cumplimiento SANDACH.'

const services = [
  {
    id: 'ganaderos',
    title: 'Servicio Ganaderos',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z" /></svg>`,
    description: 'Si tienes una explotación porcina, nos encargamos de que la gestión de tus purines cumpla toda la normativa vigente con el mínimo esfuerzo de tu parte.',
    features: [
      'Contrato anual para la gestión integral de purín',
      'Emisión de certificados oficiales de gestión',
      'Estudio de gestión eficiente del agua',
      'Tramitación de toda la documentación necesaria',
    ],
    image: '/images/cuba1.png',
    imageAlt: 'Cuba de purín en explotación porcina',
    reverse: false,
  },
  {
    id: 'analisis',
    title: 'Análisis de Laboratorio',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" /></svg>`,
    description: 'Conocer la composición de tu purín y de tus suelos es la base de una fertilización eficiente.',
    features: [
      'Análisis NPK (Nitrógeno, Fósforo, Potasio)',
      'Análisis de micronutrientes bajo pedido',
      'Análisis de suelos agrícolas',
      'Informe de recomendaciones de fertilización',
    ],
    reverse: true,
  },
  {
    id: 'agricultores',
    title: 'Servicio Agricultores',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" /></svg>`,
    description: 'Recibe el purín directamente en tu parcela y conviértelo en el fertilizante orgánico que tu cultivo necesita.',
    features: [
      'Transporte directo granja-agricultor',
      'Aplicación con sistema de tubos colgantes',
      'Anchos de trabajo: 9 metros, 15 metros y 18 metros',
      'Plan de fertilización con purines personalizado',
    ],
    image: '/images/cuba2.png',
    imageAlt: 'Aplicación de purín con tubos colgantes en campo agrícola',
    reverse: false,
  },
  {
    id: 'gestion',
    title: 'Gestión Administrativa',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>`,
    description: 'La normativa sobre gestión de deyecciones es exigente. Nosotros nos ocupamos de toda la documentación.',
    features: [
      'Control y registro de todos los movimientos de purines',
      'Libro de registro de estiércoles actualizado',
      'Sistemas informáticos especializados en registro de purines',
      'Registro SANDACH ESP22125010',
    ],
    reverse: true,
  },
  {
    id: 'gps',
    title: 'Trazabilidad GPS',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10"><path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" /></svg>`,
    description: 'Todos nuestros tractores y cisternas cuentan con sistemas GPS en tiempo real. Sabemos exactamente qué máquina está en cada parcela, cuándo llegó y cuánto purín aplicó.',
    features: [
      'Geolocalización en tiempo real de toda la maquinaria',
      'Registro automático de parcelas trabajadas y tiempos de aplicación',
      'Trazabilidad completa de cada movimiento de purín',
      'Datos exportables para auditorías e inspecciones',
    ],
    reverse: false,
  },
]
---

<PublicLayout title={title} description={description}>
  <PageHero
    title="Nuestros Servicios"
    subtitle="En Agropur gestionamos el ciclo completo del purín: desde la granja hasta el campo."
    breadcrumbs={[{ label: 'Inicio', href: '/' }, { label: 'Servicios' }]}
  />

  <!-- Services Intro -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-lg text-gray-dark max-w-3xl mx-auto text-center leading-relaxed" data-aos="fade-up">
        Nuestro modelo de gestión colectiva permite a ganaderos y agricultores beneficiarse de un servicio profesional con todas las garantías legales y técnicas.
      </p>

      <!-- Service Cycle SVG -->
      <div class="mt-12 flex justify-center" data-aos="fade-up" data-aos-delay="100">
        <div class="flex flex-wrap justify-center items-center gap-4 sm:gap-6">
          {['Granja', 'Análisis', 'Transporte', 'Campo', 'GPS', 'Asesoramiento'].map((step, i) => (
            <div class="flex items-center gap-2 sm:gap-4">
              <div class="flex flex-col items-center">
                <div class="w-14 h-14 rounded-full bg-green-primary/10 flex items-center justify-center text-green-primary font-heading font-bold text-lg">
                  {i + 1}
                </div>
                <span class="text-xs sm:text-sm font-medium text-gray-dark mt-2">{step}</span>
              </div>
              {i < 5 && (
                <svg class="w-6 h-6 text-blue-accent hidden sm:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              )}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Service Sections -->
  {services.map((service, i) => (
    <section id={service.id} class={`py-16 ${i % 2 === 1 ? 'bg-gray-brand' : 'bg-white'}`}>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class={`grid grid-cols-1 md:grid-cols-2 gap-12 items-center ${service.reverse ? 'md:flex-row-reverse' : ''}`}>
          <div class={service.reverse ? 'md:order-2' : ''} data-aos={service.reverse ? 'fade-left' : 'fade-right'}>
            <div class="flex items-center gap-3 mb-4">
              <div class="text-green-primary" set:html={service.icon} />
              <h2 class="text-2xl lg:text-3xl font-heading font-semibold text-green-primary">
                {service.title}
              </h2>
            </div>
            <p class="text-gray-dark leading-relaxed mb-6">{service.description}</p>
            <ul class="space-y-3">
              {service.features.map((feature) => (
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-green-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                  </svg>
                  <span class="text-gray-dark">{feature}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class={`flex justify-center ${service.reverse ? 'md:order-1' : ''}`} data-aos={service.reverse ? 'fade-right' : 'fade-left'}>
            {service.image ? (
              <img
                src={service.image}
                alt={service.imageAlt}
                class="w-full max-w-sm rounded-2xl shadow-md object-cover aspect-[4/3]"
                loading="lazy"
              />
            ) : (
              <div class="w-full max-w-sm bg-green-primary/8 rounded-2xl p-10 flex items-center justify-center min-h-[250px]">
                <div class="text-green-primary/30" set:html={service.icon.replace('w-10 h-10', 'w-24 h-24')} />
              </div>
            )}
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- CTA -->
  <section class="py-16 bg-green-primary">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-heading font-bold text-white mb-4" data-aos="fade-up">
        ¿Necesitas alguno de estos servicios?
      </h2>
      <p class="text-lg text-white/85 mb-8 max-w-xl mx-auto" data-aos="fade-up" data-aos-delay="100">
        Contacta con nosotros y estudiamos tu caso sin compromiso.
      </p>
      <a href="/contacto" class="inline-flex items-center px-8 py-4 bg-white text-green-primary font-bold rounded-lg hover:bg-gray-brand transition-colors shadow-lg" data-aos="fade-up" data-aos-delay="200">
        Solicitar información
      </a>
    </div>
  </section>
</PublicLayout>
