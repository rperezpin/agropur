---
import AdminLayout from '../../layouts/AdminLayout.astro'
import { getApplications, markApplicationRead } from '../../lib/db'

// Handle mark as read
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData()
  const id = formData.get('id')
  if (id) {
    markApplicationRead(Number(id))
  }
  return Astro.redirect('/admin/candidaturas')
}

const filter = Astro.url.searchParams.get('filter')
const applications = getApplications(filter === 'unread')
---

<AdminLayout title="Candidaturas">
  <!-- Filters -->
  <div class="flex gap-3 mb-6">
    <a
      href="/admin/candidaturas"
      class:list={['px-4 py-2 rounded-lg text-sm font-medium transition-colors', !filter ? 'bg-green-primary text-white' : 'bg-gray-200 text-gray-700 hover:bg-gray-300']}
    >
      Todas ({applications.length})
    </a>
    <a
      href="/admin/candidaturas?filter=unread"
      class:list={['px-4 py-2 rounded-lg text-sm font-medium transition-colors', filter === 'unread' ? 'bg-green-primary text-white' : 'bg-gray-200 text-gray-700 hover:bg-gray-300']}
    >
      No leídas
    </a>
  </div>

  {applications.length === 0 ? (
    <div class="bg-white rounded-xl p-12 text-center border border-gray-200">
      <p class="text-gray-mid">No hay candidaturas todavía.</p>
    </div>
  ) : (
    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 text-gray-600 uppercase text-xs">
            <tr>
              <th class="px-4 py-3 text-left">Fecha</th>
              <th class="px-4 py-3 text-left">Nombre</th>
              <th class="px-4 py-3 text-left">Email</th>
              <th class="px-4 py-3 text-left">Teléfono</th>
              <th class="px-4 py-3 text-left">Perfil</th>
              <th class="px-4 py-3 text-left">Experiencia</th>
              <th class="px-4 py-3 text-left">CV</th>
              <th class="px-4 py-3 text-left">Estado</th>
              <th class="px-4 py-3 text-left">Acción</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {applications.map((app) => (
              <tr class={app.leido ? 'bg-white' : 'bg-yellow-50'}>
                <td class="px-4 py-3 text-gray-500 whitespace-nowrap">{new Date(app.created_at).toLocaleDateString('es-ES')}</td>
                <td class="px-4 py-3 font-medium text-gray-900">{app.nombre}</td>
                <td class="px-4 py-3"><a href={`mailto:${app.email}`} class="text-green-primary hover:underline">{app.email}</a></td>
                <td class="px-4 py-3"><a href={`tel:${app.telefono}`} class="text-green-primary hover:underline">{app.telefono}</a></td>
                <td class="px-4 py-3">{app.perfil}</td>
                <td class="px-4 py-3 max-w-xs">
                  {app.experiencia ? (
                    <details>
                      <summary class="cursor-pointer text-gray-500 hover:text-gray-700 truncate">
                        {app.experiencia.slice(0, 40)}...
                      </summary>
                      <p class="mt-2 text-gray-700 whitespace-pre-wrap">{app.experiencia}</p>
                    </details>
                  ) : (
                    <span class="text-gray-400">—</span>
                  )}
                </td>
                <td class="px-4 py-3">
                  {app.cv_path ? (
                    <a href={`/api/admin/cv?id=${app.id}`} class="text-xs px-3 py-1 bg-blue-100 text-blue-700 rounded hover:bg-blue-200 transition-colors inline-flex items-center gap-1">
                      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
                      </svg>
                      Descargar
                    </a>
                  ) : (
                    <span class="text-gray-400 text-xs">Sin CV</span>
                  )}
                </td>
                <td class="px-4 py-3">
                  {app.leido ? (
                    <span class="px-2 py-1 rounded-full text-xs bg-green-100 text-green-700">Leído</span>
                  ) : (
                    <span class="px-2 py-1 rounded-full text-xs bg-yellow-100 text-yellow-700">Nuevo</span>
                  )}
                </td>
                <td class="px-4 py-3">
                  {!app.leido && (
                    <form method="POST">
                      <input type="hidden" name="id" value={app.id.toString()} />
                      <button type="submit" class="text-xs px-3 py-1 bg-green-primary text-white rounded hover:bg-green-primary/80 transition-colors">
                        Marcar leído
                      </button>
                    </form>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  )}
</AdminLayout>
