---
import AdminLayout from '../../layouts/AdminLayout.astro'
import { getContacts, markContactRead } from '../../lib/db'

// Handle mark as read
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData()
  const id = formData.get('id')
  if (id) {
    markContactRead(Number(id))
  }
  return Astro.redirect('/admin/contactos')
}

const filter = Astro.url.searchParams.get('filter')
const contacts = getContacts(filter === 'unread')
---

<AdminLayout title="Contactos">
  <!-- Filters -->
  <div class="flex gap-3 mb-6">
    <a
      href="/admin/contactos"
      class:list={['px-4 py-2 rounded-lg text-sm font-medium transition-colors', !filter ? 'bg-green-primary text-white' : 'bg-gray-200 text-gray-700 hover:bg-gray-300']}
    >
      Todos ({contacts.length})
    </a>
    <a
      href="/admin/contactos?filter=unread"
      class:list={['px-4 py-2 rounded-lg text-sm font-medium transition-colors', filter === 'unread' ? 'bg-green-primary text-white' : 'bg-gray-200 text-gray-700 hover:bg-gray-300']}
    >
      No leídos
    </a>
  </div>

  {contacts.length === 0 ? (
    <div class="bg-white rounded-xl p-12 text-center border border-gray-200">
      <p class="text-gray-mid">No hay mensajes de contacto todavía.</p>
    </div>
  ) : (
    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 text-gray-600 uppercase text-xs">
            <tr>
              <th class="px-4 py-3 text-left">Fecha</th>
              <th class="px-4 py-3 text-left">Nombre</th>
              <th class="px-4 py-3 text-left">Empresa</th>
              <th class="px-4 py-3 text-left">Email</th>
              <th class="px-4 py-3 text-left">Teléfono</th>
              <th class="px-4 py-3 text-left">Servicio</th>
              <th class="px-4 py-3 text-left">Mensaje</th>
              <th class="px-4 py-3 text-left">Estado</th>
              <th class="px-4 py-3 text-left">Acción</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {contacts.map((contact) => (
              <tr class={contact.leido ? 'bg-white' : 'bg-yellow-50'}>
                <td class="px-4 py-3 text-gray-500 whitespace-nowrap">{new Date(contact.created_at).toLocaleDateString('es-ES')}</td>
                <td class="px-4 py-3 font-medium text-gray-900">{contact.nombre}</td>
                <td class="px-4 py-3 text-gray-500">{contact.empresa || '—'}</td>
                <td class="px-4 py-3"><a href={`mailto:${contact.email}`} class="text-green-primary hover:underline">{contact.email}</a></td>
                <td class="px-4 py-3"><a href={`tel:${contact.telefono}`} class="text-green-primary hover:underline">{contact.telefono}</a></td>
                <td class="px-4 py-3">{contact.servicio}</td>
                <td class="px-4 py-3 max-w-xs">
                  <details>
                    <summary class="cursor-pointer text-gray-500 hover:text-gray-700 truncate">
                      {contact.mensaje.slice(0, 50)}...
                    </summary>
                    <p class="mt-2 text-gray-700 whitespace-pre-wrap">{contact.mensaje}</p>
                  </details>
                </td>
                <td class="px-4 py-3">
                  {contact.leido ? (
                    <span class="px-2 py-1 rounded-full text-xs bg-green-100 text-green-700">Leído</span>
                  ) : (
                    <span class="px-2 py-1 rounded-full text-xs bg-yellow-100 text-yellow-700">Nuevo</span>
                  )}
                </td>
                <td class="px-4 py-3">
                  {!contact.leido && (
                    <form method="POST">
                      <input type="hidden" name="id" value={contact.id.toString()} />
                      <button type="submit" class="text-xs px-3 py-1 bg-green-primary text-white rounded hover:bg-green-primary/80 transition-colors">
                        Marcar leído
                      </button>
                    </form>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  )}
</AdminLayout>
