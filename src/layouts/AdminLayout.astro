---
import BaseLayout from './BaseLayout.astro'

interface Props {
  title: string
}

const { title } = Astro.props
const currentPath = Astro.url.pathname

const navItems = [
  { label: 'Dashboard', href: '/admin' },
  { label: 'Contactos', href: '/admin/contactos' },
  { label: 'Candidaturas', href: '/admin/candidaturas' },
]
---

<BaseLayout title={`${title} | Admin Agropur`} description="Panel de administración">
  <div slot="header"></div>
  <div slot="footer"></div>

  <div class="min-h-screen flex bg-gray-100">
    <!-- Sidebar -->
    <aside class="w-64 bg-gray-dark text-white flex-shrink-0">
      <div class="p-6">
        <a href="/admin" class="flex items-center gap-3">
          <img src="/logo-agropur.jpeg" alt="Agropur" class="w-10 h-10 rounded" />
          <span class="font-heading font-bold text-lg">Admin</span>
        </a>
      </div>

      <nav class="mt-4">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'block px-6 py-3 text-sm transition-colors duration-200',
              currentPath === item.href
                ? 'bg-green-primary text-white font-medium'
                : 'text-gray-300 hover:bg-gray-700 hover:text-white',
            ]}
          >
            {item.label}
          </a>
        ))}

        <hr class="border-gray-600 my-4 mx-6" />

        <form action="/api/admin/logout" method="POST">
          <button
            type="submit"
            class="block w-full text-left px-6 py-3 text-sm text-gray-300 hover:bg-red-700 hover:text-white transition-colors duration-200"
          >
            Cerrar sesión
          </button>
        </form>
      </nav>
    </aside>

    <!-- Main content -->
    <div class="flex-1 p-8">
      <h1 class="text-2xl font-heading font-bold text-black-soft mb-6">{title}</h1>
      <slot />
    </div>
  </div>
</BaseLayout>
