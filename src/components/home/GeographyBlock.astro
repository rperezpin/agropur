---
const comarcas = [
  { name: 'Hoya de Huesca', description: 'Provincia de Huesca' },
  { name: 'Cinco Villas', description: 'Zona oeste de Zaragoza' },
  { name: 'Rivera Alta de Navarra', description: 'Sur de Navarra' },
]
---

<section class="py-16 lg:py-20 bg-gray-brand">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 items-center">
      <div data-aos="fade-right">
        <h2 class="text-3xl font-heading font-semibold text-green-primary mb-6">
          Nuestra zona de cobertura
        </h2>
        <p class="text-gray-dark leading-relaxed mb-6">
          Operamos en tres comarcas clave del nordeste de España, donde conocemos el territorio, sus ganaderos y sus necesidades.
        </p>

        <ul class="space-y-4">
          {comarcas.map((comarca) => (
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-blue-accent flex-shrink-0 mt-0.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
              <div>
                <span class="font-semibold text-black-soft">{comarca.name}</span>
                <span class="text-gray-mid text-sm ml-2">— {comarca.description}</span>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <div class="flex justify-center" data-aos="fade-left">
        <!-- Simplified geographic representation -->
        <div class="bg-white rounded-2xl p-8 shadow-sm w-full max-w-sm">
          <div class="text-center">
            <div class="w-20 h-20 mx-auto mb-4 bg-green-primary/10 rounded-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10 text-green-primary">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" />
              </svg>
            </div>
            <p class="font-heading font-semibold text-green-primary text-lg">Aragón y Navarra</p>
            <p class="text-sm text-gray-mid mt-1">Sede en Ejea de los Caballeros</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
