---

<section class="py-16 lg:py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-heading font-semibold text-green-primary text-center mb-12" data-aos="fade-up">
      ¿Por qué trabajar con Agropur?
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
      {reasons.map((reason, i) => (
        <div class="flex gap-4" data-aos="fade-up" data-aos-delay={i * 100}>
          <div class="flex-shrink-0 text-green-primary mt-1" set:html={reason.icon} />
          <div>
            <h3 class="text-lg font-heading font-semibold text-black-soft mb-2">{reason.title}</h3>
            <p class="text-gray-mid leading-relaxed">{reason.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
