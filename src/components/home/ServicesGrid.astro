---
const services = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z" /></svg>`,
    title: 'Servicio Ganaderos',
    description: 'Gestionamos el purín de tu explotación con contrato anual, certificados oficiales y estudio de eficiencia del agua.',
    href: '/servicios#ganaderos',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" /></svg>`,
    title: 'Análisis de Laboratorio',
    description: 'Análisis NPK, otros nutrientes bajo pedido y análisis de suelos para optimizar la fertilización.',
    href: '/servicios#analisis',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" /></svg>`,
    title: 'Servicio Agricultores',
    description: 'Transporte granja-agricultor, aplicación con tubos colgantes en anchos de 9, 15 y 18m y plan de fertilización.',
    href: '/servicios#agricultores',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>`,
    title: 'Gestión Administrativa',
    description: 'Control de movimientos, libro de registro de estiércoles y sistemas informáticos especializados.',
    href: '/servicios#gestion',
  },
]
---

<section class="py-16 lg:py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12" data-aos="fade-up">
      <h2 class="text-3xl font-heading font-semibold text-green-primary mb-3">
        Nuestros Servicios
      </h2>
      <p class="text-gray-mid text-lg max-w-2xl mx-auto">
        Soluciones completas para ganaderos, agricultores y gestión documental.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {services.map((service, i) => (
        <a
          href={service.href}
          class="group block bg-white border border-gray-200 rounded-xl p-6 hover:shadow-lg hover:scale-[1.02] transition-all duration-200"
          data-aos="fade-up"
          data-aos-delay={i * 100}
        >
          <div class="text-green-primary mb-4" set:html={service.icon} />
          <h3 class="text-lg font-heading font-semibold text-black-soft mb-2 group-hover:text-green-primary transition-colors">
            {service.title}
          </h3>
          <p class="text-sm text-gray-mid leading-relaxed mb-3">
            {service.description}
          </p>
          <span class="text-sm font-medium text-blue-accent group-hover:underline">
            Más información →
          </span>
        </a>
      ))}
    </div>

    <div class="text-center mt-10" data-aos="fade-up">
      <a
        href="/servicios"
        class="inline-flex items-center px-6 py-3 border-2 border-green-primary text-green-primary font-semibold rounded-lg hover:bg-green-primary hover:text-white transition-all duration-200"
      >
        Ver todos los servicios →
      </a>
    </div>
  </div>
</section>
