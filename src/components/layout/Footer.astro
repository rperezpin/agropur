---
const year = new Date().getFullYear()

const navLinks = [
  { label: 'Inicio', href: '/' },
  { label: 'Servicios', href: '/servicios' },
  { label: 'Digestato', href: '/digestato' },
  { label: 'Sobre Nosotros', href: '/sobre-nosotros' },
  { label: 'Trabaja con Nosotros', href: '/trabaja-con-nosotros' },
  { label: 'Contacto', href: '/contacto' },
]

const legalLinks = [
  { label: 'Aviso Legal', href: '/aviso-legal' },
  { label: 'Política de Privacidad', href: '/privacidad' },
  { label: 'Política de Cookies', href: '/cookies' },
]
---

<footer class="bg-gray-dark text-gray-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
      <!-- Empresa -->
      <div>
        <div class="mb-4">
          <img
            src="/logo-vect.jpeg"
            alt="Agropur Centro Gestor S.L."
            class="h-28 w-auto rounded"
          />
        </div>
        <p class="text-sm leading-relaxed mb-4">
          Agropur Centro Gestor S.L. — Gestión integral de purines y digestato en Aragón y Navarra desde 2016.
        </p>
        <p class="text-xs text-gray-400">
          Registro SANDACH Aragón: <strong class="text-green-mid">S50095004</strong><br />
          <span class="text-gray-500">Navarra: en trámite</span>
        </p>
      </div>

      <!-- Navegación -->
      <div>
        <h3 class="font-heading font-semibold text-white text-sm uppercase tracking-wider mb-4">Navegación</h3>
        <ul class="space-y-2">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm hover:text-white transition-colors duration-200"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal + Contacto -->
      <div>
        <h3 class="font-heading font-semibold text-white text-sm uppercase tracking-wider mb-4">Legal</h3>
        <ul class="space-y-2 mb-6">
          {legalLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm hover:text-white transition-colors duration-200"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>

        <h3 class="font-heading font-semibold text-white text-sm uppercase tracking-wider mb-3">Contacto</h3>
        <p class="text-sm">Ejea de los Caballeros, Zaragoza</p>
        <a href="mailto:info@agropur.es" class="text-sm hover:text-white transition-colors block">info@agropur.es</a>
        <a href="tel:+34617906103" class="text-sm hover:text-white transition-colors block">+34 617 906 103</a>
        <a
          href="https://wa.me/34617906103?text=Hola!%2C%20estar%C3%ADa%20interesado%20en%20m%C3%A1s%20informaci%C3%B3n%20sobre.."
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 mt-2 text-sm text-green-400 hover:text-green-300 transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp
        </a>
      </div>
    </div>

    <!-- Copyright -->
    <div class="border-t border-gray-600 mt-10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="text-xs text-gray-400">
        &copy; {year} Agropur Centro Gestor S.L. Todos los derechos reservados.
      </p>
      <p class="text-xs text-gray-500">
        Made with <span class="text-blue-400">♥</span> by{' '}
        <a href="https://rpidev.com" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors">rpidev</a>
      </p>
    </div>
  </div>
</footer>
