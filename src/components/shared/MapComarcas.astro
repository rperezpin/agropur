<svg
  viewBox="0 0 480 340"
  xmlns="http://www.w3.org/2000/svg"
  class="w-full h-auto"
  aria-label="Mapa de las zonas de cobertura de Agropur"
>
  <rect width="480" height="340" fill="#e9f0e8"/>
  <rect width="480" height="165" fill="#edf4ec" opacity="0.7"/>

  <!-- Bordes de provincias -->
  <path d="M 262,0 Q 248,70 234,148 Q 220,170 190,190 L 0,200"
    fill="none" stroke="#b0cead" stroke-width="1" stroke-dasharray="5,4" opacity="0.7"/>
  <path d="M 234,148 Q 340,143 480,152"
    fill="none" stroke="#b0cead" stroke-width="1" stroke-dasharray="5,4" opacity="0.7"/>
  <line x1="0" y1="262" x2="480" y2="262"
    stroke="#b0cead" stroke-width="1" stroke-dasharray="5,4" opacity="0.7"/>

  <!-- Pirineos -->
  <g fill="#9dba9a" opacity="0.45">
    <path d="M 210,9 L 222,-1 L 234,9 Z"/>
    <path d="M 232,7 L 246,-4 L 260,7 Z"/>
    <path d="M 258,6 L 274,-5 L 290,6 Z"/>
    <path d="M 286,7 L 302,-4 L 318,7 Z"/>
    <path d="M 315,6 L 330,-5 L 345,6 Z"/>
    <path d="M 341,7 L 358,-4 L 375,7 Z"/>
    <path d="M 370,8 L 385,-3 L 400,8 Z"/>
    <path d="M 397,7 L 412,-4 L 427,7 Z"/>
    <path d="M 423,8 L 437,-2 L 451,8 Z"/>
  </g>
  <text x="360" y="22" text-anchor="middle" font-size="8" fill="#7a9f77"
    font-family="Georgia, 'Times New Roman', serif" font-style="italic" letter-spacing="1.5" opacity="0.9">
    Pirineos
  </text>

  <!-- Etiquetas de provincias -->
  <text x="112" y="82" text-anchor="middle" font-size="8.5" fill="#6e9068"
    letter-spacing="3" opacity="0.5" font-family="sans-serif">NAVARRA</text>
  <text x="375" y="82" text-anchor="middle" font-size="8.5" fill="#6e9068"
    letter-spacing="3" opacity="0.5" font-family="sans-serif">HUESCA</text>
  <text x="330" y="218" text-anchor="middle" font-size="8.5" fill="#6e9068"
    letter-spacing="3" opacity="0.5" font-family="sans-serif">ZARAGOZA</text>
  <text x="240" y="305" text-anchor="middle" font-size="8" fill="#6e9068"
    letter-spacing="3" opacity="0.4" font-family="sans-serif">TERUEL</text>

  <!-- Río Ebro -->
  <path d="M 0,208 Q 80,198 170,200 Q 280,203 390,218 L 480,226"
    fill="none" stroke="#7aaecb" stroke-width="2.5" opacity="0.55"/>
  <text x="420" y="208" font-size="8" fill="#5e9ab8" font-style="italic"
    font-family="Georgia, 'Times New Roman', serif" opacity="0.85">Ebro</text>

  <!-- Zonas destacadas -->
  <ellipse cx="162" cy="133" rx="74" ry="38"
    fill="#1f5c35" fill-opacity="0.10"
    stroke="#1f5c35" stroke-width="2" stroke-opacity="0.55"
    stroke-dasharray="7,4"/>
  <ellipse cx="362" cy="97" rx="90" ry="54"
    fill="#1f5c35" fill-opacity="0.10"
    stroke="#1f5c35" stroke-width="2" stroke-opacity="0.55"
    stroke-dasharray="7,4"/>
  <ellipse cx="95" cy="183" rx="72" ry="54"
    fill="#1f5c35" fill-opacity="0.10"
    stroke="#1f5c35" stroke-width="2" stroke-opacity="0.55"
    stroke-dasharray="7,4"/>

  <!-- Ejea de los Caballeros -->
  <circle cx="128" cy="165" r="6" fill="#1a5c2e" stroke="white" stroke-width="2.5"/>
  <circle cx="128" cy="165" r="2.5" fill="white"/>
  <line x1="128" y1="171" x2="148" y2="186" stroke="#1a5c2e" stroke-width="1" opacity="0.5"/>
  <rect x="148" y="182" width="112" height="26" rx="4"
    fill="white" fill-opacity="0.92" stroke="#c0d8bc" stroke-width="0.8"/>
  <text x="204" y="193" text-anchor="middle" font-size="8.5" fill="#0e3d1e"
    font-weight="700" font-family="sans-serif">Ejea de los Caballeros</text>
  <text x="204" y="204" text-anchor="middle" font-size="7.5" fill="#3a7a50"
    font-family="sans-serif">★ sede central</text>

  <!-- Etiquetas de comarcas -->
  <text x="362" y="89" text-anchor="middle" font-size="10.5" fill="#0d3c1c"
    font-weight="700" font-family="sans-serif">Hoya de Huesca</text>
  <text x="362" y="103" text-anchor="middle" font-size="8" fill="#3a7a50"
    font-family="sans-serif">Prov. Huesca</text>

  <text x="162" y="124" text-anchor="middle" font-size="10" fill="#0d3c1c"
    font-weight="700" font-family="sans-serif">Rivera Alta</text>
  <text x="162" y="136" text-anchor="middle" font-size="8" fill="#3a7a50"
    font-family="sans-serif">de Navarra</text>

  <text x="68" y="201" text-anchor="middle" font-size="10" fill="#0d3c1c"
    font-weight="700" font-family="sans-serif">Cinco Villas</text>
  <text x="68" y="213" text-anchor="middle" font-size="8" fill="#3a7a50"
    font-family="sans-serif">Prov. Zaragoza</text>

  <!-- Rosa de los vientos -->
  <g transform="translate(450,42)">
    <circle r="16" fill="white" stroke="#c0d8bc" stroke-width="1.2"/>
    <polygon points="0,-11 3.5,-4 0,-7 -3.5,-4" fill="#1a5c2e"/>
    <polygon points="0,11 3.5,4 0,7 -3.5,4" fill="#c0c8be"/>
    <text x="0" y="4.5" text-anchor="middle" font-size="9.5" fill="#1a5c2e"
      font-weight="700" font-family="sans-serif">N</text>
  </g>

  <!-- Escala -->
  <g transform="translate(28,318)">
    <rect width="42" height="5" fill="#7a9f77" opacity="0.5"/>
    <rect x="42" width="42" height="5" fill="white" stroke="#7a9f77" stroke-width="0.8" opacity="0.7"/>
    <line x1="0" y1="0" x2="0" y2="-3" stroke="#7a9f77" stroke-width="1"/>
    <line x1="42" y1="0" x2="42" y2="-3" stroke="#7a9f77" stroke-width="1"/>
    <line x1="84" y1="0" x2="84" y2="-3" stroke="#7a9f77" stroke-width="1"/>
    <text x="0" y="14" font-size="7" fill="#6e9068" text-anchor="middle" font-family="sans-serif">0</text>
    <text x="42" y="14" font-size="7" fill="#6e9068" text-anchor="middle" font-family="sans-serif">50</text>
    <text x="86" y="14" font-size="7" fill="#6e9068" font-family="sans-serif">100 km</text>
  </g>
</svg>
