---
---

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
<div id="map-comarcas" class="w-full h-[480px]"></div>

<script is:inline>
(function () {

  /*
   * Fronteras compartidas (puntos idénticos en ambos polígonos):
   *
   * B1 — Rivera Alta (E) / Cinco Villas (NO):
   *   [42.60,-1.20] → [42.48,-1.25] → [42.35,-1.30]
   *
   * B2 — Cinco Villas (E) / Hoya de Huesca (O):
   *   [42.62,-0.82] → [42.40,-0.78] → [42.10,-0.76] → [41.90,-0.78]
   */

  /* ── Rivera Alta de Navarra ──────────────────────────────────────────
   * Zona SW de Navarra. BB: lat 42.35–42.85 | lng -1.65–-1.10
   * Incluye área de Sangüesa, Aoiz y Lumbier.
   * ──────────────────────────────────────────────────────────────────*/
  const riveraAlta = [
    [42.85, -1.62], [42.85, -1.12],
    /* B1 ↓ borde E (compartido con Cinco Villas) */
    [42.60, -1.20], [42.48, -1.25], [42.35, -1.30],
    [42.35, -1.62],
  ];

  /* ── Cinco Villas ────────────────────────────────────────────────────
   * NW de Zaragoza. BB: lat 41.83–42.62 | lng -1.42–-0.75
   * Alargada N-S; estrecha al N (montaña), ancha al S (Ebro).
   * ──────────────────────────────────────────────────────────────────*/
  const cincoVillas = [
    /* B1 ↑ borde NO (compartido con Rivera Alta) */
    [42.35, -1.30], [42.48, -1.25], [42.60, -1.20],
    /* cima estrecha → NE */
    [42.62, -0.82],
    /* B2 ↓ borde E (compartido con Hoya de Huesca) */
    [42.40, -0.78], [42.10, -0.76], [41.90, -0.78],
    /* SE y S (más ancho en la llanura del Ebro) */
    [41.83, -0.84], [41.83, -1.42],
    /* borde O irregular (límite con Navarra) */
    [41.95, -1.42], [42.08, -1.40], [42.20, -1.38],
    [42.35, -1.30],
  ];

  /* ── Hoya de Huesca ──────────────────────────────────────────────────
   * Centro-S de Huesca. BB: lat 41.90–42.60 | lng -0.75–-0.04
   * Sub-trapezoidal; más ancha al sur.
   * ──────────────────────────────────────────────────────────────────*/
  const hoyaHuesca = [
    /* B2 ↑ borde O (compartido con Cinco Villas) */
    [41.90, -0.78], [42.10, -0.76], [42.40, -0.78], [42.62, -0.82],
    /* N → NE (más estrecho arriba) */
    [42.60, -0.48], [42.52, -0.12], [42.45, -0.04],
    /* E → SE → S (más ancho abajo) */
    [42.15, -0.04], [41.90, -0.10], [41.90, -0.48],
    /* SO → cierre */
    [41.90, -0.78],
  ];

  /* ── Estilos por zona ────────────────────────────────────────────────*/
  const estilo = {
    cincoVillas: { color: '#155a2c', weight: 2, opacity: 1, fillColor: '#3a8a58', fillOpacity: 0.42 },
    hoyaHuesca:  { color: '#1a6b38', weight: 2, opacity: 1, fillColor: '#68b88a', fillOpacity: 0.38 },
    riveraAlta:  { color: '#0e3d22', weight: 2, opacity: 1, fillColor: '#1e6040', fillOpacity: 0.50 },
  };

  function labelIcon(name, sub) {
    return L.divIcon({
      className: '',
      html: `<div class="map-label"><span class="map-label-name">${name}</span><span class="map-label-sub">${sub}</span></div>`,
      iconAnchor: [0, 0],
    });
  }

  function initMap() {
    const map = L.map('map-comarcas', {
      center: [42.2, -0.9],
      zoom: 8,
      scrollWheelZoom: false,
      zoomControl: true,
    });

    /* Base cartográfica limpia, sin etiquetas */
    L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager_nolabels/{z}/{x}/{y}{r}.png', {
      maxZoom: 18,
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/">CARTO</a>',
    }).addTo(map);

    /* Polígonos */
    L.polygon(riveraAlta, estilo.riveraAlta)
      .bindTooltip('<b>Rivera Alta de Navarra</b><br><small>Comunidad Foral de Navarra</small>', { sticky: true, className: 'comarca-tooltip' })
      .addTo(map);

    L.polygon(cincoVillas, estilo.cincoVillas)
      .bindTooltip('<b>Cinco Villas</b><br><small>Prov. Zaragoza — Aragón</small>', { sticky: true, className: 'comarca-tooltip' })
      .addTo(map);

    L.polygon(hoyaHuesca, estilo.hoyaHuesca)
      .bindTooltip('<b>Hoya de Huesca</b><br><small>Prov. Huesca — Aragón</small>', { sticky: true, className: 'comarca-tooltip' })
      .addTo(map);

    /* Etiquetas permanentes */
    L.marker([42.60, -1.40], { icon: labelIcon('Rivera Alta', 'de Navarra'),    interactive: false }).addTo(map);
    L.marker([42.18, -1.10], { icon: labelIcon('Cinco Villas', 'Prov. Zaragoza'), interactive: false }).addTo(map);
    L.marker([42.22, -0.40], { icon: labelIcon('Hoya de Huesca', 'Prov. Huesca'), interactive: false }).addTo(map);

    /* Etiquetas del mapa base por encima de todo */
    map.createPane('labels');
    map.getPane('labels').style.zIndex = 650;
    map.getPane('labels').style.pointerEvents = 'none';
    L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager_only_labels/{z}/{x}/{y}{r}.png', {
      maxZoom: 18, pane: 'labels',
    }).addTo(map);

    /* Marcador sede central (Ejea de los Caballeros) */
    L.marker([42.129, -1.141], {
      icon: L.divIcon({
        className: '',
        html: '<div style="width:11px;height:11px;background:#fff;border:2.5px solid #155a2c;border-radius:50%;box-shadow:0 1px 4px rgba(0,0,0,0.45);"></div>',
        iconSize: [11, 11], iconAnchor: [5, 5],
      }),
    }).bindTooltip('<b>Ejea de los Caballeros</b><br><small>★ Sede central</small>').addTo(map);
  }

  function loadLeaflet() {
    if (window.L) { initMap(); return; }
    const s = document.createElement('script');
    s.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
    s.crossOrigin = ''; s.onload = initMap;
    document.head.appendChild(s);
  }

  document.readyState === 'loading'
    ? document.addEventListener('DOMContentLoaded', loadLeaflet)
    : loadLeaflet();
})();
</script>

<style>
  #map-comarcas { z-index: 0; }
  :global(.comarca-tooltip) {
    font-family: sans-serif;
    font-size: 13px;
    line-height: 1.5;
    padding: 6px 10px;
    border: 1px solid #b0d4aa;
    border-radius: 6px;
    box-shadow: 0 2px 6px rgba(0,0,0,0.15);
  }
  :global(.map-label) {
    display: flex;
    flex-direction: column;
    align-items: center;
    transform: translateX(-50%);
    pointer-events: none;
    text-align: center;
  }
  :global(.map-label-name) {
    font-family: sans-serif;
    font-size: 12px;
    font-weight: 700;
    color: #0d3c1c;
    text-shadow: 0 1px 3px rgba(255,255,255,0.95), 0 0 8px rgba(255,255,255,0.9);
    white-space: nowrap;
    line-height: 1.3;
  }
  :global(.map-label-sub) {
    font-family: sans-serif;
    font-size: 10px;
    color: #2d5a40;
    text-shadow: 0 1px 3px rgba(255,255,255,0.95);
    white-space: nowrap;
  }
</style>
