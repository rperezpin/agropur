---
interface Props {
  title: string
  subtitle?: string
  breadcrumbs?: { label: string; href?: string }[]
}

const { title, subtitle, breadcrumbs } = Astro.props
---

<section class="relative bg-[#1a3317] py-16 md:py-24 overflow-hidden">
  <div class="absolute inset-y-0 right-0 w-1/2 bg-green-primary/10 pointer-events-none"></div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {breadcrumbs && (
      <nav class="mb-4" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 text-sm text-white/70">
          {breadcrumbs.map((crumb, i) => (
            <li class="flex items-center gap-2">
              {i > 0 && <span aria-hidden="true">›</span>}
              {crumb.href ? (
                <a href={crumb.href} class="hover:text-white transition-colors">
                  {crumb.label}
                </a>
              ) : (
                <span class="text-white">{crumb.label}</span>
              )}
            </li>
          ))}
        </ol>
      </nav>
    )}

    <h1 class="text-3xl md:text-5xl font-heading font-bold text-white mb-4">
      {title}
    </h1>

    {subtitle && (
      <p class="text-lg md:text-xl text-white/90 max-w-3xl">
        {subtitle}
      </p>
    )}
  </div>
</section>
