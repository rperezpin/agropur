{
	"version": 3,
	"routes": [
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^\\/_server-islands\\/([^/]+?)\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/_image\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/admin\\/candidaturas\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/admin\\/contactos\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/admin\\/login\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/admin\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/admin\\/login\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/admin\\/logout\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/apply\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/contact\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/robots\\.txt\\/?$",
			"dest": "_render"
		}
	]
}